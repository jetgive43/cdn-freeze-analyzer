# Copy to .env and adjust. See backend services for all options.

DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=network_monitor

JWT_SECRET=change-me-in-production
# Public URL users open (DNS or IP), e.g. http://194.120.230.185:3000 — required for client-side http:// pings + email links.
APP_PUBLIC_URL=http://localhost:3000

# HTTP API bind address (default 0.0.0.0 = all IPv4 interfaces; use 127.0.0.1 to block remote access).
# BIND_HOST=0.0.0.0

# After `cd frontend && npm run build`, the API server also serves the React app so /admin/server-ping works on one port.
# FRONTEND_BUILD_PATH=/absolute/path/to/frontend/build

# HTTP Basic for operator UI when not using JWT (optional)
# BASIC_AUTH_USER=
# BASIC_AUTH_PASSWORD=
# BASIC_AUTH_REALM=CDN Monitor

# --- Email (verification + password reset) ---
# If SMTP_HOST is unset, signup returns verificationUrl in the API and the UI shows it;
# no message is sent. For production, configure SMTP:
#
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="App <noreply@example.com>"
#
# APP_PUBLIC_URL is also used in email links; keep it http:// if you rely on browser http:// probes.

# --- Server ping (TCP probes; history keyed by viewer region) ---
# SERVER_PING_TCP_MODE=auto|direct|socks
#   auto: use SOCKS if proxy ports exist in DB, else direct TCP from this server.
#   direct: always connect from this host (no SOAX). socks: require proxy ports.
# HTTP checks always use 3 TCP samples per target (fast public ping).
# SERVER_PING_TCP_GAP_MS=0   # ms between samples (default 0 = fastest)
# Optional ISP name on /api/server-ping/visitor (GeoLite2-ASN):
# MMDB_ASN_PATH=/path/to/GeoLite2-ASN.mmdb
# Download (same MAXMIND_LICENSE_KEY as Country): backend/scripts/download-maxmind-asn.sh

# --- Server MTR (TCP traceroute from this host; optional SOCKS via proxychains) ---
# Requires `mtr` on the server (e.g. apt install mtr-tiny). For traffic via the same SOCKS proxy as server ping,
# install proxychains4 (apt install proxychains4); auto mode falls back to direct probes if it is missing.
#
# MTR_PATH_MODE=auto|socks|direct   (default auto)
# MTR_TIMEOUT_MS=120000
# MTR_REPORT_CYCLES=8
# MTR_BIN=/usr/bin/mtr
# PROXYCHAINS_BIN=/usr/bin/proxychains4
# SOCKS5_PROXY_HOST=   # optional override; defaults to proxy host from app config
# PROXY_USER=          # same as server ping SOCKS auth
# PROXY_PASS=

# --- Business server metrics (remote agents POST to /api/business-servers/ingest) ---
# Required on the monitor/API host: base URL agents can reach (no trailing slash).
# With nginx proxying :80 → Node, use http://your-host (HTTP) or https:// if you terminate TLS.
# Example (HTTP): BUSINESS_METRICS_PUBLIC_BASE=http://server-monitor-platform.com
# BUSINESS_METRICS_PUBLIC_BASE=http://localhost:5000
#
# Ingest tokens are per row in business_servers (shown when you add a server in the UI). After setting BASE, restart the backend.
#
# Each row may set bandwidth_capacity_mbps (UI “Cap Mbps” or optional field on create); ↓/↑ columns show usage as Mbps (nn% of cap).
#
# Adding a server with SSH + password/key installs on the remote host:
#   ~/.business-metrics-agent-once.sh  — one-shot metrics + POST
#   ~/.business-metrics-bm-<id>.env    — POST_URL, INGEST_TOKEN, METRIC_NAME
#   First metrics POST runs before crontab is modified; cron is added only if that succeeds (HTTP 2xx).
#   crontab: * * * * * (every minute) sourcing the env file and running the once script
#
# Manual one-shot (no SSH from UI): same env vars, then
#   bash /path/to/backend/scripts/business-server-agent-once.sh
# Legacy continuous loop (not used by UI deploy):
#   bash /path/to/backend/scripts/business-server-agent.sh
#
# Optional: SSH private key on this API host for auto-install when creating a server via UI
# BUSINESS_SSH_PRIVATE_KEY_PATH=/home/deploy/.ssh/id_rsa
